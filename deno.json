{
   "tasks": {},
   "lint": {
      "rules": {
         "tags": [
            "recommended"
         ]
      }
   },
   "fmt": {
      "indentWidth": 3,
      "semiColons": true,
      "singleQuote": true,
      "lineWidth": 120
   },
   "exclude": [],
   "imports": {
      "@/": "./src/",
      "$std/crypto": "jsr:@std/crypto@^0.224.0",
      "$std/fs": "jsr:@std/fs@^0.224.0",
      "$std/path": "jsr:@std/path@^0.224.0",
      "ts-essentials": "npm:ts-essentials@^10.1.1"
   },
   "nodeModulesDir": "auto",
   "compilerOptions": {
      "strict": true,
      "noUncheckedIndexedAccess": true
   }
}
